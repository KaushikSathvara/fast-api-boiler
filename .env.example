# ── Application ──────────────────────────────────────────────────────────────
PROJECT_NAME=MyProject
DEBUG=false
API_V1_PREFIX=/api/v1
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Database ─────────────────────────────────────────────────────────────────
# Format: postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DB_NAME
DATABASE_URL=postgresql+asyncpg://myproject:myproject@localhost:5432/myproject
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10
DATABASE_ECHO=false

# ── Security ─────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_generate_a_secure_32_char_minimum_random_string
ACCESS_TOKEN_EXPIRE_MINUTES=60
ALGORITHM=HS256

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json     # json | console
